# ==============================================================
# Evaluaciones Docentes — Environment Variables
# ==============================================================
# Copy to .env and adjust values:  cp .env.example .env
# Used by docker-compose and application services.
# ==============================================================

# ----- PostgreSQL -----
POSTGRES_DB=evaluaciones_docentes
POSTGRES_USER=eval_user
POSTGRES_PASSWORD=eval_pass_dev
POSTGRES_PORT=5432

# ----- Redis -----
REDIS_PORT=6379

# ----- MinIO -----
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_pass_dev
MINIO_BUCKET=evaluaciones
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----- Backend -----
BACKEND_PORT=8000
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000
GEMINI_API_KEY=

# ----- Frontend -----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
