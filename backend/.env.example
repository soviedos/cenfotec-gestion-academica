# Backend — Variables de entorno (desarrollo local)
# Copiar a .env: cp .env.example .env
# En Docker estos valores se inyectan desde docker-compose.yml.

# Base de datos (requerido)
DATABASE_URL=postgresql+asyncpg://eval_user:eval_pass_dev@localhost:5432/gestion_academica

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (requerido)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_pass_dev
MINIO_BUCKET=evaluaciones
MINIO_SECURE=false

# Gemini API
GEMINI_API_KEY=

# App
ENVIRONMENT=development
LOG_LEVEL=debug
SECRET_KEY=change-this-in-production
ALLOWED_ORIGINS=http://localhost:3000
